{
  "name": "mall-admin-web",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "shadow:clean": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../../../scripts/check-shadow-js.ps1 -Fix -NoFail",
    "shadow:check": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../../../scripts/check-shadow-js.ps1",
    "dev": "pnpm run shadow:clean && vite",
    "build": "pnpm run shadow:clean && vue-tsc --noEmit && vite build && pnpm run shadow:check",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mall/api-sdk": "workspace:*",
    "axios": "^1.7.0",
    "element-plus": "^2.9.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vue-tsc": "^2.2.0"
  }
}
